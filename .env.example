# MongoDB Atlas Connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-address>/<database-name>?retryWrites=true&w=majority

# MongoDB Database Name
MONGODB_DB=kangeyan_heritage

# NextAuth Secret (Cryptographically secure random string)
NEXTAUTH_SECRET=generate-a-strong-random-secret-key-1

# JWT Secret (Cryptographically secure random string, different from NEXTAUTH_SECRET)
JWT_SECRET=generate-a-strong-random-secret-key-2

# Public URL of the deployment (e.g. http://localhost:3000 in dev)
NEXTAUTH_URL=http://localhost:3000
